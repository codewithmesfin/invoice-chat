# 1) Supabase → SQL Editor: run supabase/migrations/20250427000000_agent_invoicing.sql
# 2) If chat_sessions / chat_messages / memories are still missing, also run:
#    supabase/migrations/20250427120000_patch_agent_tables_if_missing.sql
# 3) npm run verify  (optional: E2E_EMAIL + E2E_PASSWORD for full write tests)
#
# Optional: apply migrations from your machine (Cursor cannot open your Dashboard).
# DIRECT_URL=postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
# Then: npm run db:apply
#
# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Prefer JWT anon key (eyJ...). Lovable publishable keys also work if named:
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_JWT
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Or derive URL from project id only:
# NEXT_PUBLIC_SUPABASE_PROJECT_ID=your_project_ref

# OpenRouter (https://openrouter.ai/keys) — use free chat + free embedding models
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_CHAT_MODEL=meta-llama/llama-3.2-3b-instruct:free
# Comma-separated fallbacks when a free model is rate-limited (404/429/503):
OPENROUTER_CHAT_MODEL_FALLBACKS=openrouter/auto
OPENROUTER_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
# Optional: vision model for receipt screenshots in chat (default: free Llama vision)
# OPENROUTER_VISION_MODEL=meta-llama/llama-3.2-11b-vision-instruct:free

# Public URL of this app (Stripe return URLs, pay links in emails). For local dev:
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: set to your real origin (https://…). Emails and APIs also use the incoming
# request Host when possible, and VERCEL_URL on Vercel, so localhost is not used in prod links.
# Optional server-only canonical URL (recommended if NEXT_PUBLIC_* was baked wrong at build):
# APP_URL=https://your-production-domain.com

# Stripe (Dashboard → Developers → API keys). Webhooks are NOT required: after payment,
# Stripe redirects to /pay/return?session_id=… and the app verifies the session server-side.
STRIPE_SECRET_KEY=sk_test_...

# --- Option A: Django-style MAIL_* (works with Gmail) ---
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_STARTTLS=True
# MAIL_SSL_TLS=False
# MAIL_USERNAME=you@gmail.com
# MAIL_PASSWORD=xxxx xxxx xxxx xxxx
# MAIL_FROM=you@gmail.com
# MAIL_FROM_NAME=My Business Name
#
# --- Option B: SMTP_* / GMAIL_* ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Optional: set to true for port 465 SSL
# SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your-16-char-app-password
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=your-16-char-app-password
#
# From header — optional if same as login; or use MAIL_FROM / EMAIL_FROM
# EMAIL_FROM="My Studio <you@gmail.com>"

# Supabase service role (Dashboard → Settings → API) — server only; never expose to the client
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Optional: protect /api/cron/invoice-reminders (Authorization: Bearer <secret>)
CRON_SECRET=change-me-in-production

# Optional: npm run verify will sign in and test customer + chat row inserts
# E2E_EMAIL=test@example.com
# E2E_PASSWORD=your_password
